Algoritmo "dardos"

Var

   a,b,c,maior : real

Inicio

   escreva("Digite as tres distancias: ")
   leia(a,b,c)
   
   se (a > b) e (a > c) entao
      escreva("MAIOR DISTANCIA = ", a)
   senao
      se (b > c) entao
         escreva("MAIOR DISTANCIA = ", b)
      senao
         escreva("MAIOR DISTANCIA = ", c)
      fimse
    fimse
    
    
Fimalgoritmo