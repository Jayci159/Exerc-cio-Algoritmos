Algoritmo "glicose"

Var

   glicose : real
   classe : caractere

Inicio

   escreva("Digite a medida da glicose: ")
   leia(glicose)

   se glicose <= 100.0 entao
      escreval("ClassificaÓÐo: Normal")
   senao
     se (glicose > 100.0) e (glicose <= 140) entao
       escreval("ClassificaÓÐo: Elevado")
     senao
       escreval("ClassificaÓÐo: Diabetes")
     fimse
    fimse
    
Fimalgoritmo