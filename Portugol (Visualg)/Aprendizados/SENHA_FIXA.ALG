Algoritmo "senha_fixa"


Var

   senha: inteiro

Inicio

   escreva("Digite a senha: ")
   leia(senha)
   
   enquanto senha <> 2002 faca
      escreva("Senha inválida! Tente Novamente: ")
      leia(senha)
   fimenquanto
   
   se senha = 2002 entao
     escreva("Acesso permitido!")
   fimse
   

Fimalgoritmo